{
  "publisher": "kittybbit",
  "name": "vscode-ajsbutler",
  "displayName": "vscode-ajsbutler",
  "description": "Support tool for JP1/AJS3",
  "version": "1.14.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "homepage": "https://github.com/kittybbit/vscode-ajsbutler",
  "repository": {
    "type": "git",
    "url": "https://github.com/kittybbit/vscode-ajsbutler"
  },
  "bugs": {
    "url": "https://github.com/kittybbit/vscode-ajsbutler/issues"
  },
  "engines": {
    "node": ">=20",
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "JP1/AJS"
  ],
  "main": "./out/extension.js",
  "browser": "./out/web.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "ajsbutler.tableViewer",
        "displayName": "JP1/AJS table viewer",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "ajsbutler.flowViewer",
        "displayName": "JP1/AJS flow viewer",
        "selector": [
          {
            "filenamePattern": "*"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "enablement": "editorLangId == 'jp1ajs'",
        "command": "open.ajsbutler.flowViewer",
        "category": "View",
        "title": "Open JP1/AJS flow viewer",
        "shortTitle": "JP1/AJS flow viewer",
        "icon": "$(circuit-board)"
      },
      {
        "enablement": "editorLangId == 'jp1ajs'",
        "command": "open.ajsbutler.tableViewer",
        "category": "View",
        "title": "Open JP1/AJS table viewer",
        "shortTitle": "JP1/AJS table viewer",
        "icon": "$(output)"
      },
      {
        "command": "ajsbutler.importDefinitionViaWebApiBeta",
        "category": "JP1/AJS",
        "title": "Import JP1/AJS Definition via WebAPI (Beta)",
        "shortTitle": "Import via WebAPI (Beta)",
        "icon": "$(cloud-download)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "editorLangId == 'jp1ajs'",
          "command": "open.ajsbutler.flowViewer",
          "group": "navigation"
        },
        {
          "when": "editorLangId == 'jp1ajs'",
          "command": "open.ajsbutler.tableViewer",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "jp1ajs",
        "aliases": [
          "JP1/AJS",
          "jp1ajs",
          "JP1",
          "AJS"
        ],
        "extensions": [
          ""
        ],
        "configuration": "./language/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "jp1ajs",
        "scopeName": "source.ajs",
        "path": "./syntax/jp1ajs.tmLanguage.json"
      }
    ]
  },
  "activationEvents": [
    "onCommand:ajsbutler.importDefinitionViaWebApiBeta",
    "onWebviewPanel:ajsbutler.tableViewer",
    "onWebviewPanel:ajsbutler.flowViewer"
  ],
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "clean": "rimraf out report",
    "development": "webpack",
    "development:desktop": "webpack --env target=desktop",
    "development:web": "webpack --env target=web",
    "prebuild": "pnpm run clean",
    "build": "webpack --mode production",
    "antlr4ts": "npm-run-all antlr:clean antlr:generate",
    "antlr:clean": "rimraf src/generate/parser",
    "antlr:generate": "antlr4ts -o src/generate/parser -Xexact-output-dir src/antlr/*.g4",
    "watch": "webpack -w",
    "test:prepare": "npm-run-all development test:compile",
    "test:prepare:desktop": "npm-run-all development:desktop test:compile",
    "test:prepare:web": "npm-run-all development:web test:compile",
    "pretest": "pnpm run test:prepare:desktop",
    "pretest:web": "pnpm run test:prepare:web",
    "test:compile": "tsc -p tsconfig.test.json",
    "test:desktop:run": "node ./out/test/runTest.js",
    "test:web:run": "node ./out/test/runWebTest.js",
    "test:full": "npm-run-all test:prepare test:desktop:run test:web:run",
    "qlty": "npm-run-all qlty:fmt qlty:check",
    "qlty:fmt": "qlty fmt",
    "qlty:check": "qlty check",
    "lint:md": "npx markdownlint-cli2 'docs/specs/features/**/*.md' 'docs/requirements/use-cases/**/*.md'",
    "openapi:generate": "node scripts/generate-webapi-openapi-artifacts.mjs",
    "openapi:check": "node scripts/generate-webapi-openapi-artifacts.mjs --check",
    "openapi:mock": "prism mock src/test/fixtures/webapi/generated/jp1Ajs3WebApi.prism.generated.yaml",
    "test": "node ./out/test/runTest.js",
    "test:web": "node ./out/test/runWebTest.js"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.1",
    "@stoplight/prism-cli": "^5.15.10",
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.10",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-window": "^1.8.8",
    "@types/styled-components": "^5.1.36",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.75.0",
    "@types/vscode-webview": "^1.57.5",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/test-web": "^0.0.80",
    "@vscode/vsce": "^3.9.1",
    "antlr4ts-cli": "^0.5.0-alpha.4",
    "css-loader": "^7.1.2",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^11.1.0",
    "globals": "^16.5.0",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "playwright": "1.59.1",
    "process": "^0.11.10",
    "rimraf": "^6.1.2",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "webpack": "^5.106.2",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "yaml": "1.10.3"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/table-core": "^8.21.3",
    "@vscode/extension-telemetry": "^1.2.0",
    "@xyflow/react": "^12.9.3",
    "antlr4ts": "^0.5.0-alpha.4",
    "assert": "^2.1.0",
    "classnames": "^2.5.1",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-virtuoso": "^4.14.1",
    "util": "^0.12.5",
    "uuid": "^11.1.0",
    "xxhash-wasm": "^1.1.0"
  },
  "pnpm": {
    "overrides": {
      "ajv@6.12.6": "6.14.0",
      "ajv@8.17.1": "8.18.0",
      "brace-expansion@1.1.12": "1.1.13",
      "diff": "8.0.3",
      "elliptic": "^6.5.6",
      "flatted": "3.4.2",
      "jws": "3.2.3",
      "koa": "3.1.2",
      "lodash": "4.18.0",
      "markdown-it": "14.1.1",
      "minimatch@3.1.2": "3.1.4",
      "minimatch@3.1.3": "3.1.4",
      "minimatch@9.0.5": "9.0.7",
      "minimatch@10.1.1": "10.2.3",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "qs": "6.14.2",
      "serialize-javascript": "7.0.5",
      "underscore": "1.13.8",
      "undici": "7.24.0",
      "ws": ">=7.5.10",
      "yaml": "1.10.3"
    }
  }
}
